---
interface Props {
  title?: string;
  description?: string;
}

const { title = "Vigil", description = "Evaluating how AI assistants handle conversations with mentally vulnerable users." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300..800;1,6..72,300..800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="site-nav">
      <div class="nav-inner">
        <a href="/blog" class="nav-logo">
          <img src="/flower.svg" alt="" class="nav-flower" aria-hidden="true" />
          <span class="nav-title">vigil</span>
        </a>
        <div class="nav-status" aria-label="Site status">Draft / Work in progress</div>
        <div class="nav-links">
          <a href="/blog">Research</a>
          <a href="https://github.com/timf34/vigil" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-ascii" aria-hidden="true">
          <pre>{`    *  .  *
   .\\  |  /.
  — · \\|/ · —
   ·\` ';' \`·
    '/ | \\'
       |
  ,.;,|;.,;,.`}</pre>
        </div>
        <div class="footer-content">
          <p class="footer-tagline">[placeholder]</p>
          <p class="footer-links">
            <a href="https://github.com/timf34/vigil" target="_blank" rel="noopener">Source</a>
            <span class="footer-sep">&middot;</span>
            <a href="/blog">Research</a>
          </p>
          <p class="footer-credit">Built by <a href="https://timfarrelly.com" target="_blank" rel="noopener">Tim Farrelly</a> &middot; Thank you to <a href="https://bluedot.org" target="_blank" rel="noopener">BlueDot</a> for supporting</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* ===== CSS Reset & Variables ===== */
  :root {
    --cream: #fbf8f3;
    --cream-warm: #f7f1e8;
    --parchment: #e7ddd0;
    --ink: #151310;
    --ink-soft: #3f3a33;
    --ink-muted: #726a5f;
    --ink-faint: #a99f91;
    --sage: #6b7c5e;
    --sage-light: #8a9e7a;
    --sage-pale: #dde6d5;
    --amber: #c48a3f;
    --amber-light: #e8b86d;
    --amber-pale: #f5e6cc;
    --rose: #c4665e;
    --rose-light: #d98a83;
    --rose-pale: #f5ddd9;
    --green-good: #5e8a5e;
    --yellow-mid: #b8963f;
    --orange-warn: #c47a3f;
    --red-bad: #b85a4a;

    --font-serif: 'Newsreader', Georgia, 'Times New Roman', serif;
    --font-mono: 'DM Mono', 'Menlo', 'Consolas', monospace;

    --max-width: 1080px;
    --max-width-wide: 1200px;
    --gutter: clamp(1rem, 4vw, 3rem);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    font-size: 16px;
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }

  body {
    font-family: var(--font-serif);
    color: var(--ink);
    background:
      radial-gradient(circle at 18% 8%, rgba(226, 216, 201, 0.52), transparent 28rem),
      radial-gradient(circle at 80% 18%, rgba(240, 231, 219, 0.56), transparent 26rem),
      linear-gradient(180deg, #fbf9f5 0%, var(--cream) 42%, #faf7f1 100%);
    line-height: 1.6;
    min-height: 100vh;
  }

  a {
    color: var(--sage);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  a:hover {
    color: var(--ink);
  }

  ::selection {
    background: var(--amber-pale);
    color: var(--ink);
  }

  /* ===== Navigation ===== */
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(251, 248, 243, 0.78);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--parchment);
  }

  .nav-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 0.85rem var(--gutter);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 1rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--ink);
    text-decoration: none;
    justify-self: start;
  }

  .nav-logo:hover { color: var(--ink); }

  .nav-flower {
    height: 24px;
    width: auto;
    opacity: 0.8;
    transition: opacity 0.15s;
  }

  .nav-logo:hover .nav-flower {
    opacity: 1;
  }

  .nav-title {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: lowercase;
  }

  .nav-status {
    justify-self: center;
    padding: 0.18rem 0.48rem;
    border: 1px solid var(--amber-pale);
    border-radius: 4px;
    background: rgba(245, 230, 204, 0.48);
    color: var(--amber);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    line-height: 1.2;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .nav-links {
    display: flex;
    justify-self: end;
    gap: clamp(1rem, 3vw, 2.3rem);
    font-family: var(--font-serif);
    font-size: 0.95rem;
  }

  .nav-links a {
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .nav-links a:hover {
    color: var(--ink);
  }

  /* ===== Main ===== */
  main {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  /* ===== Footer ===== */
  .site-footer {
    margin-top: 6rem;
    border-top: 1px solid var(--parchment);
    background: var(--cream-warm);
  }

  .footer-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 3rem var(--gutter);
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .footer-ascii pre {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    line-height: 1.15;
    color: var(--ink-faint);
    margin: 0;
  }

  .footer-tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--ink-soft);
    margin-bottom: 0.5rem;
  }

  .footer-links {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-muted);
  }

  .footer-links a {
    color: var(--ink-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer-links a:hover { color: var(--ink); }

  .footer-sep { margin: 0 0.5rem; }

  .footer-credit {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--ink-faint);
    margin-top: 0.4rem;
  }

  .footer-credit a {
    color: var(--ink-faint);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer-credit a:hover { color: var(--ink-muted); }

  /* ===== Responsive ===== */
  @media (max-width: 600px) {
    .nav-inner { padding: 0.75rem var(--gutter); }
    .nav-status { display: none; }
    .nav-links { gap: 0.8rem; font-size: 0.82rem; }
    .nav-flower { height: 22px; }
    .footer-inner { flex-direction: column; text-align: center; }
    .footer-ascii { display: none; }
  }
</style>
