---
import { existsSync, readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import Layout from '../../layouts/Layout.astro';
import leaderboardData from '../../../public/leaderboard-data.json';
import modelCardsData from '../../../public/model-cards.json';

function shortModelName(model: string) {
  return model.replace(/^openrouter\//, '').split('/').pop() ?? model;
}

function displayName(m: string) {
  return shortModelName(m);
}

function modelSlug(model: any): string {
  return model.slug ?? `${encodeURIComponent(displayName(model.target_model))}--${model.timestamp}`;
}

export function getStaticPaths() {
  const paths: any[] = [];

  for (const model of leaderboardData.models) {
    const slug = model.slug ?? `${encodeURIComponent(shortModelName(model.target_model))}--${model.timestamp}`;
    paths.push({
      params: { slug },
      props: { model },
    });
  }

  return paths;
}

const { model } = Astro.props;
const modelCard = (modelCardsData as any)[modelSlug(model)] ?? null;
const dimensions = leaderboardData.dimensions;
const dimDescriptions = leaderboardData.dimension_descriptions as Record<string, string>;

function severityLabel(val: number | null): string {
  if (val == null) return '';
  if (val <= 1.5) return 'sev-1';
  if (val <= 2.5) return 'sev-2';
  if (val <= 3.5) return 'sev-3';
  if (val <= 4.5) return 'sev-4';
  return 'sev-5';
}

function stateDisplayName(key: string): string {
  return key.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

function barWidth(val: number | null): string {
  if (val == null) return '0%';
  return `${(val / 5) * 100}%`;
}

function cleanTextBlock(text: string | null | undefined): string {
  if (!text) return '';
  return text.replace(/\*\*/g, '').replace(/[ \t]+\n/g, '\n').trim();
}

function loadStatePages(slug: string, stateMap: Record<string, any>): Record<string, any> {
  const pages: Record<string, any> = {};

  for (const stateKey of Object.keys(stateMap ?? {})) {
    const statePageUrl = new URL(
      `../../../public/state-pages/${slug}/${stateKey}.json`,
      import.meta.url
    );
    const statePagePath = fileURLToPath(statePageUrl);
    if (!existsSync(statePagePath)) {
      continue;
    }
    pages[stateKey] = JSON.parse(readFileSync(statePagePath, 'utf-8'));
  }

  return pages;
}

const name = displayName(model.target_model);
const slug = modelSlug(model);
const states = Object.entries(model.states).sort(
  ([, a]: any, [, b]: any) => (b.weighted_mean ?? 0) - (a.weighted_mean ?? 0)
);
const statePages = loadStatePages(slug, model.states ?? {});
const characterization = modelCard?.model_characterization || modelCard?.summary_blurb || 'Model characterization unavailable for this run.';
---

<Layout title={`${name} — Vigil`} description={`Detailed Vigil evaluation results for ${name}`}>

  <section class="model-header">
    <a href="/" class="back-link">&larr; Back to leaderboard</a>
    <h1 class="model-title">{name}</h1>
    <div class="model-meta-row">
      <span class="meta-item">
        <span class="meta-label">Overall</span>
        <span class={`meta-value overall-val ${severityLabel(model.overall_weighted_mean)}`}>
          {model.overall_weighted_mean?.toFixed(2) ?? '—'}
        </span>
      </span>
      <span class="meta-item">
        <span class="meta-label">Scenarios</span>
        <span class="meta-value">{model.total_scenarios}</span>
      </span>
      <span class="meta-item">
        <span class="meta-label">States</span>
        <span class="meta-value">{model.num_states}</span>
      </span>
    </div>
  </section>

  <!-- ===== Model Card ===== -->
  {modelCard && (
    <section class="model-card-section">

      <div class="archetype-row">
        <span class="archetype-label">Signature</span>
        <span class="archetype-value">{modelCard.short_label}</span>
      </div>

      <p class="model-characterization">{characterization}</p>

      {modelCard.summary_blurb && modelCard.summary_blurb !== characterization && (
        <p class="model-blurb">{modelCard.summary_blurb}</p>
      )}

      {modelCard.warning_labels?.length > 0 && (
        <div class="concerns-block">
          <h3 class="pattern-heading concerns-heading">Clinical concerns</h3>
          <div class="concerns-list">
            {modelCard.warning_labels.map((w: string) => (
              <div class="concern-item">
                <span class="concern-icon">&#9651;</span>
                {w}
              </div>
            ))}
          </div>
        </div>
      )}

      <div class="model-drilldown">
        <div class="rates-col">
          <h3 class="pattern-heading">Behavioral rates</h3>
          <dl class="rates-list">
            {Object.entries(modelCard.behavior_rates ?? {}).map(([key, val]: [string, any]) => (
              <div class="rate-row">
                <dt class="rate-key">{key.replace(/_/g, ' ')}</dt>
                <dd class="rate-val">
                  <div class="rate-bar-track">
                    <div class="rate-bar-fill" style={`width: ${Math.round((val as number) * 100)}%`} />
                  </div>
                  <span class="rate-pct">{Math.round((val as number) * 100)}%</span>
                </dd>
              </div>
            ))}
          </dl>
        </div>

        {(modelCard.recurring_protective_patterns?.length > 0 || modelCard.recurring_risky_patterns?.length > 0) && (
          <div class="patterns-panel">
            <h3 class="pattern-heading">Recurring patterns</h3>
            <div class="patterns-grid">
              {modelCard.recurring_protective_patterns?.length > 0 && (
                <div class="pattern-col">
                  <h4 class="pattern-subheading protective">Protective</h4>
                  <ul class="pattern-list">
                    {modelCard.recurring_protective_patterns.map((p: string) => (
                      <li class="pattern-item protective">{p}</li>
                    ))}
                  </ul>
                </div>
              )}
              {modelCard.recurring_risky_patterns?.length > 0 && (
                <div class="pattern-col">
                  <h4 class="pattern-subheading risky">Risky</h4>
                  <ul class="pattern-list">
                    {modelCard.recurring_risky_patterns.map((p: string) => (
                      <li class="pattern-item risky">{p}</li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </div>
        )}
      </div>

    </section>
  )}

  <!-- Overall dimension scores -->
  <section class="overview-section">
    <h2 class="section-label">Aggregate scores</h2>
    <div class="overview-bars">
      {dimensions.map((d: string) => {
        const val = model.overall_mean_severity?.[d];
        return (
          <div class="bar-row">
            <div class="bar-label">
              <span class="bar-dim">{d}</span>
              <span class={`bar-val ${severityLabel(val)}`}>{val?.toFixed(1) ?? '—'}</span>
            </div>
            <div class="bar-track">
              <div class={`bar-fill ${severityLabel(val)}`} style={`width: ${barWidth(val)}`} />
            </div>
            <div class="bar-desc">{dimDescriptions[d]}</div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Per-state breakdown -->
  <section class="states-section">
    <h2 class="section-label">Performance by vulnerability state</h2>
    <div class="states-list">
      {states.map(([stateKey, stateData]: [string, any]) => {
        const statePage = statePages[stateKey];
        const scenarios = statePage?.scenarios ?? [];
        const dossier = modelCard?.state_dossiers?.[stateKey];

        return (
          <details class="state-toggle" id={stateKey}>
            <summary class="state-toggle-summary">
              <div class="state-card">
                <div class="state-header">
                  <h3 class="state-name">{stateDisplayName(stateKey)}</h3>
                  <span class={`state-overall ${severityLabel(stateData.weighted_mean)}`}>
                    {stateData.weighted_mean?.toFixed(2)}
                  </span>
                </div>
                <div class="state-meta">{stateData.num_scenarios} scenarios</div>

                <div class="state-scores">
                  {dimensions.map((d: string) => {
                    const val = stateData.mean_severity?.[d];
                    return (
                      <div class="state-score-row">
                        <span class="state-dim">{d.slice(0, 5)}.</span>
                        <div class="state-bar-track">
                          <div class={`state-bar-fill ${severityLabel(val)}`} style={`width: ${barWidth(val)}`} />
                        </div>
                        <span class={`state-val ${severityLabel(val)}`}>{val?.toFixed(1)}</span>
                      </div>
                    );
                  })}
                </div>

                {dossier?.summary && (
                  <div class="state-dossier">
                    <p class="dossier-text">{dossier.summary}</p>
                  </div>
                )}

                <div class="state-scenarios-link">
                  <span class="scenarios-link-text">
                    {scenarios.length ? `${scenarios.length} expandable scenarios` : 'Scenario data unavailable'}
                  </span>
                  <span class="scenarios-link-arrow">+</span>
                </div>
              </div>
            </summary>

            <div class="state-toggle-body">
              {scenarios.length ? (
                <div class="scenario-toggle-list">
                  {scenarios.map((scenario: any) => (
                    <details class="scenario-toggle">
                      <summary class="scenario-toggle-summary">
                        <div class="scenario-summary-head">
                          <div class="scenario-title-wrap">
                            <span class="scenario-kicker">Scenario {scenario.scenario_number}</span>
                            <span class="scenario-title">{scenario.title}</span>
                          </div>
                          <span class={`scenario-weighted ${severityLabel(scenario.weighted_mean)}`}>
                            {scenario.weighted_mean?.toFixed(2) ?? '—'}
                          </span>
                        </div>

                        <div class="scenario-mini-scores">
                          {dimensions.map((d: string) => {
                            const val = scenario.scores?.[d];
                            return (
                              <span class={`scenario-mini-pill ${severityLabel(val)}`}>
                                {d.slice(0, 5)} {val?.toFixed(1) ?? '—'}
                              </span>
                            );
                          })}
                        </div>
                      </summary>

                      <div class="scenario-toggle-body">
                        {scenario.description && (
                          <div class="scenario-block">
                            <h4 class="scenario-block-heading">Scenario setup</h4>
                            <div class="scenario-copy">{cleanTextBlock(scenario.description)}</div>
                          </div>
                        )}

                        {scenario.overall_assessment && (
                          <div class="scenario-block">
                            <h4 class="scenario-block-heading">Judge assessment</h4>
                            <div class="scenario-copy">{scenario.overall_assessment}</div>
                          </div>
                        )}

                        <div class="transcript-block">
                          <h4 class="scenario-block-heading">Transcript</h4>
                          {scenario.transcript?.turns?.length ? (
                            <div class="turns-list">
                              {scenario.transcript.turns.map((turn: any) => (
                                <div class="turn-group">
                                  <div class="turn turn-user">
                                    <div class="turn-label">User {turn.turn_number}</div>
                                    <div class="turn-text">{turn.user_message}</div>
                                  </div>

                                  {turn.assistant_message && (
                                    <div class="turn turn-assistant">
                                      <div class="turn-label">Assistant</div>
                                      <div class="turn-text">{turn.assistant_message}</div>
                                    </div>
                                  )}
                                </div>
                              ))}
                            </div>
                          ) : (
                            <p class="state-empty">Transcript unavailable for this scenario.</p>
                          )}
                        </div>
                      </div>
                    </details>
                  ))}
                </div>
              ) : (
                <p class="state-empty">Scenario transcript data unavailable for this state.</p>
              )}
            </div>
          </details>
        );
      })}
    </div>
  </section>

</Layout>

<style>
  /* ===== Model Header ===== */
  .model-header {
    padding: 2.5rem 0 1.4rem;
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1rem;
    transition: color 0.15s;
  }

  .back-link:hover { color: var(--ink); }

  .model-title {
    font-family: var(--font-mono);
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  .model-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .meta-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-faint);
  }

  .meta-value {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--ink-soft);
    font-weight: 500;
  }

  .overall-val {
    font-size: 1.3rem;
    font-weight: 600;
  }

  /* ===== Model Card ===== */
  .model-card-section {
    padding: 0 0 2.5rem;
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--parchment);
  }

  .archetype-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1.15rem;
  }

  .archetype-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-faint);
  }

  .archetype-value {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-style: italic;
    font-weight: 600;
    color: var(--ink);
  }

  .model-blurb {
    font-family: var(--font-serif);
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--ink-soft);
    margin-bottom: 1.4rem;
    max-width: 820px;
  }

  .model-characterization {
    font-family: var(--font-serif);
    font-size: 2rem;
    line-height: 1.25;
    color: var(--ink);
    margin-bottom: 1.1rem;
    max-width: 940px;
  }

  .concerns-block {
    margin: 1.5rem 0 1.6rem;
    padding: 1rem 0;
    border-top: 1px solid rgba(236, 228, 216, 0.8);
    border-bottom: 1px solid rgba(236, 228, 216, 0.8);
  }

  .concerns-heading {
    margin-bottom: 0.65rem;
  }

  .concerns-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 0.45rem 1.1rem;
  }

  .concern-item {
    font-family: var(--font-serif);
    font-size: 0.88rem;
    color: var(--orange-warn);
    line-height: 1.45;
    display: flex;
    gap: 0.55rem;
    align-items: baseline;
  }

  .concern-icon {
    font-size: 0.6rem;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .model-drilldown {
    padding-top: 1.4rem;
    border-top: 1px solid var(--parchment);
  }

  .pattern-heading {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-muted);
    margin-bottom: 0.75rem;
  }

  .patterns-panel {
    margin-top: 1.35rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--parchment);
  }

  .patterns-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.4rem;
  }

  .pattern-subheading {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }

  .pattern-subheading.protective { color: var(--sage); }
  .pattern-subheading.risky { color: var(--orange-warn); }

  .pattern-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .pattern-item {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    line-height: 1.4;
    padding-left: 0.9rem;
    position: relative;
  }

  .pattern-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
  }

  .pattern-item.protective { color: var(--sage); }
  .pattern-item.protective::before { background: var(--sage); }
  .pattern-item.risky { color: var(--orange-warn); }
  .pattern-item.risky::before { background: var(--orange-warn); }

  .rates-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.6rem 1.4rem;
    margin: 0;
  }

  .rate-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.5rem;
    align-items: center;
  }

  .rate-key {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--ink-muted);
    text-transform: capitalize;
  }

  .rate-val {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    grid-column: 1 / -1;
  }

  .rate-bar-track {
    flex: 1;
    height: 4px;
    background: var(--parchment);
    border-radius: 2px;
    overflow: hidden;
  }

  .rate-bar-fill {
    height: 100%;
    background: var(--sage-light);
    border-radius: 2px;
  }

  .rate-pct {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--ink-muted);
    width: 2.5rem;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  /* ===== State Dossier ===== */
  .state-dossier {
    margin-top: 0.8rem;
    padding-top: 0.8rem;
    border-top: 1px solid rgba(236, 228, 216, 0.6);
  }

  .dossier-text {
    font-family: var(--font-serif);
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--ink-soft);
    font-style: italic;
  }

  /* ===== Overview Bars ===== */
  .overview-section {
    margin-bottom: 3rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-muted);
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--parchment);
  }

  .overview-bars {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    max-width: 700px;
  }

  .bar-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    grid-template-rows: auto auto;
    gap: 0.2rem 1rem;
    align-items: center;
  }

  .bar-label {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .bar-dim {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: capitalize;
    color: var(--ink);
  }

  .bar-val {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .bar-track {
    height: 8px;
    background: var(--parchment);
    border-radius: 4px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.4s ease;
  }

  .bar-fill.sev-1, .bar-fill.sev-2 { background: var(--sage-light); }
  .bar-fill.sev-3 { background: var(--amber); }
  .bar-fill.sev-4 { background: var(--orange-warn); }
  .bar-fill.sev-5 { background: var(--red-bad); }

  .bar-desc {
    grid-column: 1 / -1;
    font-family: var(--font-serif);
    font-size: 0.78rem;
    color: var(--ink-muted);
    font-style: italic;
  }

  /* ===== States ===== */
  .states-section {
    margin-bottom: 3rem;
  }

  .states-intro {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    color: var(--ink-muted);
    font-style: italic;
    margin-bottom: 1.5rem;
  }

  .states-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .state-toggle {
    background: white;
    border: 1px solid var(--parchment);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .state-toggle[open] {
    border-color: var(--ink-faint);
    box-shadow: 0 2px 8px rgba(44, 36, 24, 0.05);
  }

  .state-toggle-summary,
  .scenario-toggle-summary {
    list-style: none;
    cursor: pointer;
  }

  .state-toggle-summary::-webkit-details-marker,
  .scenario-toggle-summary::-webkit-details-marker {
    display: none;
  }

  .state-card {
    padding: 1.2rem 1.4rem;
  }

  .state-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.3rem;
  }

  .state-name {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
  }

  .state-overall {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .state-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-faint);
    margin-bottom: 0.8rem;
  }

  .state-scores {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .state-score-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .state-dim {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--ink-muted);
    width: 3.5rem;
    text-transform: capitalize;
  }

  .state-bar-track {
    flex: 1;
    height: 5px;
    background: var(--parchment);
    border-radius: 3px;
    overflow: hidden;
  }

  .state-bar-fill {
    height: 100%;
    border-radius: 3px;
  }

  .state-bar-fill.sev-1, .state-bar-fill.sev-2 { background: var(--sage-light); }
  .state-bar-fill.sev-3 { background: var(--amber); }
  .state-bar-fill.sev-4 { background: var(--orange-warn); }
  .state-bar-fill.sev-5 { background: var(--red-bad); }

  .state-val {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    width: 2rem;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .state-scenarios-link {
    margin-top: 0.8rem;
    padding-top: 0.8rem;
    border-top: 1px dashed var(--parchment);
