---
import Layout from '../../layouts/Layout.astro';
import leaderboardData from '../../../public/leaderboard-data.json';
import modelCardsData from '../../../public/model-cards.json';

function shortModelName(model: string) {
  return model.replace(/^openrouter\//, '').split('/').pop() ?? model;
}

function displayName(m: string) {
  return shortModelName(m);
}

function modelSlug(model: any): string {
  return model.slug ?? `${encodeURIComponent(displayName(model.target_model))}--${model.timestamp}`;
}

export function getStaticPaths() {
  const paths: any[] = [];

  for (const model of leaderboardData.models) {
    const slug = model.slug ?? `${encodeURIComponent(shortModelName(model.target_model))}--${model.timestamp}`;
    paths.push({
      params: { slug },
      props: { model },
    });
  }

  return paths;
}

const { model } = Astro.props;
const modelCard = (modelCardsData as any)[modelSlug(model)] ?? null;
const runCard = (leaderboardData.runs as any[]).find((run: any) => run.timestamp === model.timestamp) ?? null;
const dimensions = leaderboardData.dimensions;
const dimDescriptions = leaderboardData.dimension_descriptions as Record<string, string>;

function severityLabel(val: number | null): string {
  if (val == null) return '';
  if (val <= 1.5) return 'sev-1';
  if (val <= 2.5) return 'sev-2';
  if (val <= 3.5) return 'sev-3';
  if (val <= 4.5) return 'sev-4';
  return 'sev-5';
}

function statusClass(status: string): string {
  return `status-${status}`;
}

function stageClass(status: string): string {
  return `stage-${status}`;
}

function stateDisplayName(key: string): string {
  return key.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

function barWidth(val: number | null): string {
  if (val == null) return '0%';
  return `${(val / 5) * 100}%`;
}

const name = displayName(model.target_model);
const states = Object.entries(model.states).sort(
  ([, a]: any, [, b]: any) => (b.weighted_mean ?? 0) - (a.weighted_mean ?? 0)
);
---

<Layout title={`${name} — Vigil`} description={`Detailed Vigil evaluation results for ${name}`}>

  <section class="model-header">
    <a href="/" class="back-link">&larr; Back to leaderboard</a>
    <h1 class="model-title">{name}</h1>
    <div class="model-meta-row">
      <span class="meta-item">
        <span class="meta-label">Overall</span>
        <span class={`meta-value overall-val ${severityLabel(model.overall_weighted_mean)}`}>
          {model.overall_weighted_mean?.toFixed(2) ?? '—'}
        </span>
      </span>
      <span class="meta-item">
        <span class="meta-label">Judge</span>
        <span class="meta-value">{model.judge_label}</span>
      </span>
      <span class="meta-item">
        <span class="meta-label">Scenarios</span>
        <span class="meta-value">{model.total_scenarios}</span>
      </span>
      <span class="meta-item">
        <span class="meta-label">States</span>
        <span class="meta-value">{model.num_states}</span>
      </span>
      <span class="meta-item">
        <span class="meta-label">Run</span>
        <span class="meta-value">{model.timestamp}</span>
      </span>
    </div>
  </section>

  <section class="run-provenance-section">
    <div class="run-provenance-card">
      <div class="run-provenance-head">
        <div>
          <h2 class="section-label run-section-label">Run Provenance</h2>
          <p class="run-name">{model.run_label}</p>
        </div>
        <span class={`status-pill ${statusClass(model.status)}`}>{model.status_label}</span>
      </div>

      <p class="run-use">{model.recommended_use}</p>

      <div class="run-freshness">
        <span class={`freshness-pill ${stageClass(model.transcripts_status)}`}>Transcripts: {model.transcripts_status}</span>
        <span class={`freshness-pill ${stageClass(model.stage4_status)}`}>Stage 4: {model.stage4_status}</span>
        <span class={`freshness-pill ${stageClass(model.stage5_status)}`}>Stage 5: {model.stage5_status}</span>
      </div>

      <p class="run-note">{model.notes}</p>

      {runCard && (
        <div class="run-meta-grid">
          <div class="run-meta-item">
            <span class="run-meta-label">Batch</span>
            <span class="run-meta-value">{runCard.model_count} models / {runCard.state_count} states</span>
          </div>
          <div class="run-meta-item">
            <span class="run-meta-label">Evaluator</span>
            <span class="run-meta-value">{displayName(runCard.evaluator_model)}</span>
          </div>
          <div class="run-meta-item">
            <span class="run-meta-label">Profile model</span>
            <span class="run-meta-value">{displayName(runCard.characterization_model)}</span>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ===== Model Card ===== -->
  {modelCard && (
    <section class="model-card-section">

      <div class="archetype-row">
        <span class="archetype-label">Archetype</span>
        <span class="archetype-value">{modelCard.archetype}</span>
      </div>

      <p class="model-blurb">{modelCard.summary_blurb}</p>

      {modelCard.warning_labels?.length > 0 && (
        <div class="warning-labels">
          {modelCard.warning_labels.map((w: string) => (
            <div class="warning-label">
              <span class="warning-icon">&#9651;</span>
              {w}
            </div>
          ))}
        </div>
      )}

      <div class="card-columns">
        <div class="pattern-col">
          <h3 class="pattern-heading protective">Protective patterns</h3>
          <ul class="pattern-list">
            {modelCard.recurring_protective_patterns?.map((p: string) => (
              <li class="pattern-item protective">{p}</li>
            ))}
          </ul>
        </div>
        <div class="pattern-col">
          <h3 class="pattern-heading risky">Risky patterns</h3>
          <ul class="pattern-list">
            {modelCard.recurring_risky_patterns?.map((p: string) => (
              <li class="pattern-item risky">{p}</li>
            ))}
          </ul>
        </div>
        <div class="rates-col">
          <h3 class="pattern-heading">Behavioral rates</h3>
          <dl class="rates-list">
            {Object.entries(modelCard.behavior_rates ?? {}).map(([key, val]: [string, any]) => (
              <div class="rate-row">
                <dt class="rate-key">{key.replace(/_/g, ' ')}</dt>
                <dd class="rate-val">
                  <div class="rate-bar-track">
                    <div class="rate-bar-fill" style={`width: ${Math.round((val as number) * 100)}%`} />
                  </div>
                  <span class="rate-pct">{Math.round((val as number) * 100)}%</span>
                </dd>
              </div>
            ))}
          </dl>
        </div>
      </div>

    </section>
  )}

  <!-- Overall dimension scores -->
  <section class="overview-section">
    <h2 class="section-label">Aggregate scores</h2>
    <div class="overview-bars">
      {dimensions.map((d: string) => {
        const val = model.overall_mean_severity?.[d];
        return (
          <div class="bar-row">
            <div class="bar-label">
              <span class="bar-dim">{d}</span>
              <span class={`bar-val ${severityLabel(val)}`}>{val?.toFixed(1) ?? '—'}</span>
            </div>
            <div class="bar-track">
              <div class={`bar-fill ${severityLabel(val)}`} style={`width: ${barWidth(val)}`} />
            </div>
            <div class="bar-desc">{dimDescriptions[d]}</div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Per-state breakdown -->
  <section class="states-section">
    <h2 class="section-label">Performance by vulnerability state</h2>
    <div class="states-grid">
      {states.map(([stateKey, stateData]: [string, any]) => (
        <div class="state-card" id={stateKey}>
          <div class="state-header">
            <h3 class="state-name">{stateDisplayName(stateKey)}</h3>
            <span class={`state-overall ${severityLabel(stateData.weighted_mean)}`}>
              {stateData.weighted_mean?.toFixed(2)}
            </span>
          </div>
          <div class="state-meta">{stateData.num_scenarios} scenarios</div>

          <div class="state-scores">
            {dimensions.map((d: string) => {
              const val = stateData.mean_severity?.[d];
              return (
                <div class="state-score-row">
                  <span class="state-dim">{d.slice(0, 5)}.</span>
                  <div class="state-bar-track">
                    <div class={`state-bar-fill ${severityLabel(val)}`} style={`width: ${barWidth(val)}`} />
                  </div>
                  <span class={`state-val ${severityLabel(val)}`}>{val?.toFixed(1)}</span>
                </div>
              );
            })}
          </div>

          {(() => {
            const dossier = modelCard?.state_dossiers?.[stateKey];
            return dossier?.summary ? (
              <div class="state-dossier">
                <p class="dossier-text">{dossier.summary}</p>
              </div>
            ) : (
              <div class="state-scenarios-placeholder">
                <p class="placeholder-text">Scenario transcripts coming soon</p>
              </div>
            );
          })()}
        </div>
      ))}
    </div>
  </section>

</Layout>

<style>
  /* ===== Model Header ===== */
  .model-header {
    padding: 2.5rem 0 2rem;
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1rem;
    transition: color 0.15s;
  }

  .back-link:hover { color: var(--ink); }

  .model-title {
    font-family: var(--font-mono);
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  .model-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .meta-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-faint);
  }

  .meta-value {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--ink-soft);
    font-weight: 500;
  }

  .overall-val {
    font-size: 1.3rem;
    font-weight: 600;
  }

  .status-pill,
  .freshness-pill {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.22rem 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.64rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 1px solid transparent;
    white-space: nowrap;
  }

  .status-current,
  .stage-current,
  .stage-valid {
    background: rgba(107, 124, 94, 0.12);
    color: var(--sage);
    border-color: rgba(107, 124, 94, 0.18);
  }

  .status-rejudge_needed,
  .stage-stale {
    background: rgba(181, 111, 71, 0.12);
    color: var(--orange-warn);
    border-color: rgba(181, 111, 71, 0.18);
  }

  /* ===== Run Provenance ===== */
  .run-provenance-section {
    margin-bottom: 2rem;
  }

  .run-provenance-card {
    background: white;
    border: 1px solid var(--parchment);
    border-radius: 8px;
    padding: 1.3rem 1.5rem;
  }

  .run-provenance-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.8rem;
  }

  .run-section-label {
    margin-bottom: 0.4rem;
    border-bottom: none;
    padding-bottom: 0;
  }

  .run-name {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--ink);
    margin: 0;
  }

  .run-use,
  .run-note {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0 0 0.8rem;
  }

  .run-freshness {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 0.8rem;
  }

  .run-meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0.8rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--parchment);
  }

  .run-meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .run-meta-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
  }

  .run-meta-value {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--ink);
  }

  /* ===== Model Card ===== */
  .model-card-section {
    background: white;
    border: 1px solid var(--parchment);
    border-radius: 8px;
    padding: 1.8rem 2rem;
    margin-bottom: 3rem;
  }

  .archetype-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .archetype-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-faint);
  }

  .archetype-value {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-style: italic;
    font-weight: 600;
    color: var(--ink);
  }

  .model-blurb {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--ink-soft);
    margin-bottom: 1.2rem;
    max-width: 780px;
  }

  .warning-labels {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }

  .warning-label {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: var(--orange-warn);
    line-height: 1.5;
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
  }

  .warning-icon {
    font-size: 0.6rem;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .card-columns {
    display: grid;
    grid-template-columns: 1fr 1fr 1.2fr;
    gap: 2rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--parchment);
  }

  .pattern-heading {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-muted);
    margin-bottom: 0.75rem;
  }

  .pattern-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .pattern-item {
    font-family: var(--font-serif);
    font-size: 0.85rem;
    line-height: 1.4;
    padding-left: 0.9rem;
    position: relative;
  }

  .pattern-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
  }

  .pattern-item.protective { color: var(--sage); }
  .pattern-item.protective::before { background: var(--sage); }
  .pattern-item.risky { color: var(--orange-warn); }
  .pattern-item.risky::before { background: var(--orange-warn); }

  .rates-list {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    margin: 0;
  }

  .rate-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.5rem;
    align-items: center;
  }

  .rate-key {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--ink-muted);
    text-transform: capitalize;
  }

  .rate-val {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    grid-column: 1 / -1;
  }

  .rate-bar-track {
    flex: 1;
    height: 4px;
    background: var(--parchment);
    border-radius: 2px;
    overflow: hidden;
  }

  .rate-bar-fill {
    height: 100%;
    background: var(--sage-light);
    border-radius: 2px;
  }

  .rate-pct {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--ink-muted);
    width: 2.5rem;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  /* ===== State Dossier ===== */
  .state-dossier {
    margin-top: 0.8rem;
    padding-top: 0.8rem;
    border-top: 1px solid rgba(236, 228, 216, 0.6);
  }

  .dossier-text {
    font-family: var(--font-serif);
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--ink-soft);
    font-style: italic;
  }

  /* ===== Overview Bars ===== */
  .overview-section {
    margin-bottom: 3rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-muted);
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--parchment);
  }

  .overview-bars {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    max-width: 700px;
  }

  .bar-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    grid-template-rows: auto auto;
    gap: 0.2rem 1rem;
    align-items: center;
  }

  .bar-label {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .bar-dim {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: capitalize;
    color: var(--ink);
  }

  .bar-val {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .bar-track {
    height: 8px;
    background: var(--parchment);
    border-radius: 4px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.4s ease;
  }

  .bar-fill.sev-1, .bar-fill.sev-2 { background: var(--sage-light); }
  .bar-fill.sev-3 { background: var(--amber); }
  .bar-fill.sev-4 { background: var(--orange-warn); }
  .bar-fill.sev-5 { background: var(--red-bad); }

  .bar-desc {
    grid-column: 1 / -1;
    font-family: var(--font-serif);
    font-size: 0.78rem;
    color: var(--ink-muted);
    font-style: italic;
  }

  /* ===== States ===== */
  .states-section {
    margin-bottom: 3rem;
  }

  .states-intro {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    color: var(--ink-muted);
    font-style: italic;
    margin-bottom: 1.5rem;
  }

  .states-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.2rem;
  }

  .state-card {
    background: white;
    border: 1px solid var(--parchment);
    border-radius: 8px;
    padding: 1.2rem 1.4rem;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .state-card:hover {
    border-color: var(--ink-faint);
    box-shadow: 0 2px 8px rgba(44, 36, 24, 0.05);
  }

  .state-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.3rem;
  }

  .state-name {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
  }

  .state-overall {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .state-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-faint);
    margin-bottom: 0.8rem;
  }

  .state-scores {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .state-score-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .state-dim {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--ink-muted);
    width: 3.5rem;
    text-transform: capitalize;
  }

  .state-bar-track {
    flex: 1;
    height: 5px;
    background: var(--parchment);
    border-radius: 3px;
    overflow: hidden;
  }

  .state-bar-fill {
    height: 100%;
    border-radius: 3px;
  }

  .state-bar-fill.sev-1, .state-bar-fill.sev-2 { background: var(--sage-light); }
  .state-bar-fill.sev-3 { background: var(--amber); }
  .state-bar-fill.sev-4 { background: var(--orange-warn); }
  .state-bar-fill.sev-5 { background: var(--red-bad); }

  .state-val {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    width: 2rem;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .state-scenarios-placeholder {
    margin-top: 0.8rem;
    padding-top: 0.8rem;
    border-top: 1px dashed var(--parchment);
  }

  .placeholder-text {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-faint);
    font-style: italic;
  }

  /* Severity colors */
  .sev-1 { color: var(--green-good); }
  .sev-2 { color: var(--sage); }
  .sev-3 { color: var(--yellow-mid); }
  .sev-4 { color: var(--orange-warn); }
  .sev-5 { color: var(--red-bad); }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .card-columns {
      grid-template-columns: 1fr 1fr;
    }
    .rates-col {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 768px) {
    .card-columns {
      grid-template-columns: 1fr;
    }
    .bar-row {
      grid-template-columns: 120px 1fr;
    }

    .states-grid {
      grid-template-columns: 1fr;
    }

    .model-meta-row {
      gap: 1rem;
    }
  }
</style>
